rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidNickname(value) {
      return value is string
        && value.size() >= 2
        && value.size() <= 10;
    }

    function isValidNicknameLowercased(value) {
      return value is string
        && value.size() >= 2
        && value.size() <= 10;
    }

    function isOptionalString(data, field, maxSize) {
      return !(field in data)
        || (data[field] is string && data[field].size() <= maxSize);
    }

    function isOptionalTimestamp(data, field) {
      return !(field in data) || data[field] is timestamp;
    }

    function isOptionalStringList(data, field, maxItems) {
      return !(field in data)
        || (data[field] is list && data[field].size() <= maxItems);
    }

    function isValidTastingUsageContext(data) {
      return !('usageContext' in data)
        || data.usageContext in ['오늘 사용', '최근 사용', '기억으로 기록'];
    }

    function isValidTastingLongevityExperience(data) {
      return !('longevityExperience' in data)
        || data.longevityExperience in ['2h 이하', '2~4h', '4~6h', '6h+'];
    }

    function isValidTastingSillageExperience(data) {
      return !('sillageExperience' in data)
        || data.sillageExperience in ['나만 맡음', '주변 1m', '방 전체'];
    }

    function isValidTastingDrydownChange(data) {
      return !('drydownChange' in data)
        || data.drydownChange in ['거의 비슷함', '조금 달라짐', '완전히 달라짐'];
    }

    function isValidTastingSkinChemistry(data) {
      return !('skinChemistry' in data)
        || data.skinChemistry in ['더 살아남', '그대로', '죽는 편'];
    }

    function isValidUserProfile(data) {
      return data.keys().hasOnly([
        'nickname',
        'nicknameLowercased',
        'tasteAnalysis',
        'contactEmail',
        'onboardingCompleted',
        'experienceLevel',
        'updatedAt',
        'createdAt'
      ])
      && isValidNickname(data.nickname)
      && isValidNicknameLowercased(data.nicknameLowercased)
      && data.tasteAnalysis is map
      && (!('contactEmail' in data) || data.contactEmail is string)
      && (!('onboardingCompleted' in data) || data.onboardingCompleted is bool)
      && (!('experienceLevel' in data) || data.experienceLevel is string)
      && data.updatedAt is timestamp
      && data.createdAt is timestamp;
    }

    function isValidLikedPerfume(data) {
      return data.keys().hasOnly([
        'name',
        'brand',
        'imageUrl',
        'mainAccords',
        'likedAt',
        'topNotes',
        'middleNotes',
        'baseNotes',
        'generalNotes',
        'seasonRanking',
        'concentration',
        'longevity',
        'sillage'
      ])
      && data.name is string
      && data.brand is string
      && data.mainAccords is list
      && data.likedAt is timestamp
      && (!('imageUrl' in data) || data.imageUrl is string)
      && (!('topNotes' in data) || data.topNotes is list)
      && (!('middleNotes' in data) || data.middleNotes is list)
      && (!('baseNotes' in data) || data.baseNotes is list)
      && (!('generalNotes' in data) || data.generalNotes is list)
      && (!('seasonRanking' in data) || data.seasonRanking is list)
      && (!('concentration' in data) || data.concentration is string)
      && (!('longevity' in data) || data.longevity is string)
      && (!('sillage' in data) || data.sillage is string);
    }

    function isValidCollectionItem(data) {
      return data.keys().hasOnly([
        'name',
        'brand',
        'imageUrl',
        'imageURL',
        'mainAccords',
        'scentFamily',
        'scentFamily2',
        'accordStrengths',
        'concentration',
        'gender',
        'memo',
        'addedAt',
        'createdAt',
        'updatedAt',
        'topNotes',
        'middleNotes',
        'baseNotes',
        'generalNotes',
        'seasonRanking',
        'longevity',
        'sillage',
        'usageStatus',
        'usageFrequency',
        'preferenceLevel',
        'registrationEditCount'
      ])
      && data.name is string
      && data.brand is string
      && (!('mainAccords' in data) || data.mainAccords is list)
      && (!('accordStrengths' in data) || data.accordStrengths is map)
      && isOptionalTimestamp(data, 'addedAt')
      && isOptionalTimestamp(data, 'createdAt')
      && data.updatedAt is timestamp
      && (!('imageUrl' in data) || data.imageUrl is string)
      && (!('imageURL' in data) || data.imageURL is string)
      && (!('scentFamily' in data) || data.scentFamily is string)
      && (!('scentFamily2' in data) || data.scentFamily2 is string)
      && (!('concentration' in data) || data.concentration is string)
      && (!('gender' in data) || data.gender is string)
      && (!('memo' in data) || data.memo is string)
      && (!('topNotes' in data) || data.topNotes is list)
      && (!('middleNotes' in data) || data.middleNotes is list)
      && (!('baseNotes' in data) || data.baseNotes is list)
      && (!('generalNotes' in data) || data.generalNotes is list)
      && (!('seasonRanking' in data) || data.seasonRanking is list)
      && (!('longevity' in data) || data.longevity is string)
      && (!('sillage' in data) || data.sillage is string)
      && (!('usageStatus' in data) || data.usageStatus is string)
      && (!('usageFrequency' in data) || data.usageFrequency is string)
      && (!('preferenceLevel' in data) || data.preferenceLevel is string)
      && (!('registrationEditCount' in data) || (
        data.registrationEditCount is int
        && data.registrationEditCount >= 0
        && data.registrationEditCount <= 3
      ));
    }

    function isValidCollectionCreate(data) {
      return isValidCollectionItem(data)
        && (!('registrationEditCount' in data) || data.registrationEditCount == 0);
    }

    function isValidCollectionUpdate(previousData, nextData) {
      return isValidCollectionItem(nextData)
        && (
          (!('registrationEditCount' in previousData) && nextData.registrationEditCount == 1)
          || (
            ('registrationEditCount' in previousData)
            && nextData.registrationEditCount == previousData.registrationEditCount + 1
          )
        );
    }

    function isValidTastingRecord(data) {
      return data.keys().hasOnly([
        'perfumeName',
        'brandName',
        'imageUrl',
        'perfumeImageURL',
        'mainAccords',
        'accordStrengths',
        'rating',
        'moodTags',
        'memo',
        'wantToRevisit',
        'revisitDesire',
        'usageContext',
        'longevityExperience',
        'sillageExperience',
        'drydownChange',
        'skinChemistry',
        'wearSituations',
        'weatherContexts',
        'applicationAreas',
        'concentration',
        'createdAt',
        'updatedAt'
      ])
      && data.perfumeName is string
      && data.brandName is string
      && data.mainAccords is list
      && (!('accordStrengths' in data) || data.accordStrengths is map)
      && data.rating is int
      && data.rating >= 0
      && data.rating <= 5
      && data.moodTags is list
      && isOptionalString(data, 'memo', 2000)
      && isOptionalString(data, 'wantToRevisit', 50)
      && isOptionalString(data, 'revisitDesire', 50)
      && isValidTastingUsageContext(data)
      && isValidTastingLongevityExperience(data)
      && isValidTastingSillageExperience(data)
      && isValidTastingDrydownChange(data)
      && isValidTastingSkinChemistry(data)
      && isOptionalStringList(data, 'wearSituations', 4)
      && isOptionalStringList(data, 'weatherContexts', 4)
      && isOptionalStringList(data, 'applicationAreas', 4)
      && isOptionalString(data, 'imageUrl', 1000)
      && isOptionalString(data, 'perfumeImageURL', 1000)
      && isOptionalString(data, 'concentration', 80)
      && isOptionalTimestamp(data, 'createdAt')
      && data.updatedAt is timestamp;
    }

    function isValidAccordCache(data) {
      return data.keys().hasOnly([
        'accord',
        'subFamily',
        'confidence',
        'source',
        'createdAt',
        'updatedAt'
      ])
      && data.accord is string
      && data.subFamily is string
      && data.confidence is number
      && data.confidence >= 0
      && data.confidence <= 1
      && data.source is string
      && data.createdAt is timestamp
      && data.updatedAt is timestamp;
    }

    function isValidProfileHistory(data) {
      return data.keys().hasOnly([
        'title',
        'families',
        'scentVector',
        'collectionCount',
        'tastingCount',
        'stage',
        'createdAt'
      ])
      && data.title is string
      && data.families is list
      && data.scentVector is map
      && data.collectionCount is int
      && data.collectionCount >= 0
      && data.tastingCount is int
      && data.tastingCount >= 0
      && data.stage is string
      && data.createdAt is timestamp;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);

      // 현재 앱은 닉네임 중복 확인을 위해 users 컬렉션에 whereField("nicknameLowercased") 쿼리를 날림
      // 그래서 인증 사용자에 한해 list/query 를 허용해야 함
      allow list: if isSignedIn();

      allow create: if isOwner(userId)
        && isValidUserProfile(request.resource.data);

      allow update: if isOwner(userId)
        && isValidUserProfile(request.resource.data)
        && resource.data.createdAt == request.resource.data.createdAt;

      allow delete: if isOwner(userId);

      match /collection/{perfumeId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
          && isValidCollectionCreate(request.resource.data);
        allow update: if isOwner(userId)
          && isValidCollectionUpdate(resource.data, request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /likes/{perfumeId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId)
          && isValidLikedPerfume(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /tastingRecords/{recordId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
          && isValidTastingRecord(request.resource.data)
          && request.resource.data.createdAt is timestamp;
        allow update: if isOwner(userId)
          && isValidTastingRecord(request.resource.data)
          && resource.data.createdAt == request.resource.data.createdAt;
        allow delete: if isOwner(userId);
      }

      match /profileHistory/{historyId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
          && isValidProfileHistory(request.resource.data);
        allow update: if false;
        allow delete: if isOwner(userId);
      }
    }

    match /accordCache/{accordId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn()
        && isValidAccordCache(request.resource.data);
    }
  }
}
